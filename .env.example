# ===========================================
# Myenge ma bonakristo — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# The app runs in three modes depending on which vars are set:
#   - Full mode: all vars set (Prisma + Supabase)
#   - DB-only mode: DATABASE_URL set (database works, auth/storage mocked)
#   - Mock mode: no vars set (runs on JSON mock data)

# -------------------------------------------
# Database (Prisma + PostgreSQL via Supabase)
# -------------------------------------------
DATABASE_URL=

# -------------------------------------------
# Supabase (Auth + Storage)
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------
# App Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
