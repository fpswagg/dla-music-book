    {
      "id": "song-1",
      "index": 1,
      "title": "Nya Loba",
      "status": "FINISHED",
      "createdAt": "2024-01-15T00:00:00Z",
      "updatedAt": "2024-06-01T00:00:00Z",
      "authors": [{ "id": "author-1", "name": "Pasteur Ndedi Eyango", "displayOrder": 1 }],
      "tags": [{ "id": "tag-1", "key": "spiritual", "name": { "fr": "Spirituel", "en": "Spiritual", "duala": "Mudi" }, "category": "MOOD" }, { "id": "tag-2", "key": "praise", "name": { "fr": "Louange", "en": "Praise", "duala": "Tombédi" }, "category": "THEME" }],
      "languages": [{ "id": "lang-duala", "code": "duala", "name": { "fr": "Duala", "en": "Duala", "duala": "Duala" } }],
      "versions": [
        {
          "id": "ver-1-1",
          "versionType": "ORIGINAL",
          "versionNumber": 1,
          "lyrics": "Nya Loba, Nya Loba\nO mudi na bwam\nO mudi na bwam, Nya Loba\nNa sango na wé\n\nO ma pula mba na nyo\nO ma téyédi mba bunya\nNya Loba, Nya Loba\nNa tombédi wé",
          "annotations": [
            {
              "id": "ann-1",
              "lineNumber": 1,
              "lineText": "Nya Loba, Nya Loba",
              "note": "\"Nya Loba\" signifie \"Dieu\" en langue Duala. Cette ouverture est une invocation directe."
            }
          ]
        }
      ],
      "notes": []
    },
    {
